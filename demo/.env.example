# AnimaWorks Demo — Environment Variables
# Copy this file to .env and fill in your values.

# Required: Anthropic API key for Claude models
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXX

# Preset to use (en-business | en-anime | ja-business | ja-anime)
# Style: business = realistic avatars, anime = anime-style avatars
PRESET=en-business

# Timezone (default: Asia/Tokyo)
# TZ=Asia/Tokyo
